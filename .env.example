# Supabase — create a project at https://supabase.com, then run the SQL in
# supabase/migrations/0001_init.sql in the SQL editor.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — Project Settings > API > service_role. Server-only, never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Mapbox — public token from https://account.mapbox.com/access-tokens/
# Exposed to the browser (required for client-side map rendering).
NEXT_PUBLIC_MAPBOX_TOKEN=

# Google Maps Platform — needs Geocoding API and Directions API enabled.
# https://console.cloud.google.com/google/maps-apis
# Server-only.
GOOGLE_MAPS_API_KEY=

# NVIDIA NIM — used for PDF/URL/free-text itinerary extraction.
# Same key as the JaeTravel Media Hub's vision/captioning API, if reusing it.
# Get a free key (no credit card) at https://build.nvidia.com — sign up,
# then generate a key (prefixed nvapi-) from your account.
# Free tier: ~40 requests/minute shared across all NIM calls on this key.
NVIDIA_API_KEY=
